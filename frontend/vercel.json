{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sandblast-petty-salute.ngrok-free.dev/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://sandblast-petty-salute.ngrok-free.dev/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "/api"
    }
  }
}